<Project Sdk="Microsoft.NET.Sdk">
  <PropertyGroup>
    <TargetFramework>net6.0</TargetFramework>
    <ImplicitUsings>enable</ImplicitUsings>
    <Nullable>disable</Nullable>
    <ModZipPath>$(MSBuildProjectDirectory)</ModZipPath>
    <EnableModZip Condition="'$(GamePath)' != ''">true</EnableModZip>
    <EnableModDeploy Condition="'$(GamePath)' != ''">false</EnableModDeploy>
  </PropertyGroup>
  <ItemGroup>
    <PackageReference Include="Pathoschild.Stardew.ModBuildConfig" Version="4.4.0" />
  </ItemGroup>
  <ItemGroup>
    <TranslationFiles Include="i18n/**" />
  </ItemGroup>
</Project>
